/* stylelint-disable */
@import "tailwindcss";

@theme {
  --color-background: var(--bg);
  --color-foreground: var(--tx);
  --font-sans: 'Poppins', sans-serif;
  --font-mono: 'DM Mono', monospace;

  --radius-xl: 1rem;
  --radius-2xl: 1.5rem;
  --radius-3xl: 2rem;

  --color-gn: #107539;
  --color-gn-light: #f4fbf7;
  --color-earth: #835626;
}

:root {
  --bg: #fafaf9;
  --bgA: #f5f5f4;
  --bgB: #efeee9;
  --bgC: #ffffff;

  --bd: rgba(0, 0, 0, 0.08);
  --bdM: rgba(0, 0, 0, 0.12);

  --tx: #0c0a09;
  --t2: #44403c;
  --t3: #78716c;
  --t4: #a8a29e;

  --gn: #107539;
  --g-glow: rgba(16, 117, 57, 0.15);

  --ea: #835626;

  --section-py: clamp(3rem, 4vw, 4rem);
  --container-px: clamp(1.2rem, 4vw, 4rem);
}

*,
*::before,
*::after {
  box-sizing: border-box;
}

html {
  overflow-x: hidden;
  max-width: 100vw;
}

body {
  font-family: 'Poppins', sans-serif;
  background: var(--bg);
  color: var(--tx);
  line-height: 1.5;
  overflow-x: hidden;
  max-width: 100vw;
  -webkit-font-smoothing: antialiased;
}

/* ─── PREMIUM GRADIENTS ─── */
.bg-lush {
  background: radial-gradient(circle at 50% -20%, #effaf3 0%, #fafaf9 60%);
}

.bg-earth-subtle {
  background: radial-gradient(circle at 0% 0%, #fefaf6 0%, transparent 100%);
}

/* ─── GLASSMORPHISM ─── */
.glass {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.glass-dark {
  background: rgba(12, 10, 9, 0.8);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

/* ─── SHADOWS ─── */
.premium-shadow {
  box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.05),
    0 0 1px 0 rgba(0, 0, 0, 0.1);
}

.glow-gn {
  box-shadow: 0 0 30px 0 var(--g-glow);
}

/* ─── TYPOGRAPHY ─── */
h1,
h2,
h3,
h4 {
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.1;
}

.text-gradient {
  background: linear-gradient(135deg, var(--tx) 0%, #44403c 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.text-gn-gradient {
  background: linear-gradient(135deg, var(--gn) 0%, #169248 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* ─── UTILITIES ─── */
.section-max {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 var(--container-px);
}

.section-py {
  padding: var(--section-py) 0;
}

.card-premium {
  background: white;
  border: 1px solid var(--bd);
  border-radius: 24px;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
}

.card-premium:hover {
  transform: translateY(-4px);
  border-color: var(--gn);
  box-shadow: 0 20px 60px -20px rgba(16, 117, 57, 0.1);
}

/* ─── ANIMATIONS ─── */
@keyframes reveal {
  from {
    opacity: 0;
    transform: translateY(20px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-reveal {
  animation: reveal 0.8s cubic-bezier(0.23, 1, 0.32, 1) both;
}

.dot-blink {
  animation: blink 2s infinite;
}

@keyframes blink {

  0%,
  100% {
    opacity: 1;
    transform: scale(1);
  }

  50% {
    opacity: 0.4;
    transform: scale(0.9);
  }
}

/* ─── CUSTOM SCROLLBAR ─── */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: #d6d3d1;
  border-radius: 10px;
}

::-webkit-scrollbar-thumb:hover {
  background: #a8a29e;
}